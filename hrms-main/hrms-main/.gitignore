# Root .gitignore

# Dependencies
node_modules/
**/node_modules/

# Environment files (secrets - never commit)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Build outputs
**/build/
**/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Local uploads directory
**/uploads/

# Scratch scripts
**/scratch/

# VSCode
.vscode/

# SQL dump (large - optional to ignore)
# hrms.sql
