{
  "version": 2,
  "builds": [
    {
      "src": "hrms-main/hrms-main/backend-hrms/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "hrms-main/hrms-main/frontend-hrms/package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "CI=false npm run build",
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/hrms-main/hrms-main/backend-hrms/src/index.ts"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/hrms-main/hrms-main/backend-hrms/src/index.ts"
    },
    {
      "source": "/ping",
      "destination": "/hrms-main/hrms-main/backend-hrms/src/index.ts"
    },
    {
      "source": "/(static/.*)",
      "destination": "/hrms-main/hrms-main/frontend-hrms/$1"
    },
    {
      "source": "/(favicon\\.ico|manifest\\.json|logo192\\.png|logo512\\.png|robots\\.txt)",
      "destination": "/hrms-main/hrms-main/frontend-hrms/$1"
    },
    {
      "source": "/((?!api|uploads|ping).*)",
      "destination": "/hrms-main/hrms-main/frontend-hrms/index.html"
    }
  ]
}
